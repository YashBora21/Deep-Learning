from tensorflow.keras.preprocessing.image import ImageDataGenerator

train_gen = ImageDataGenerator(
    rescale=1./255,
    rotation_range=20,
    zoom_range=0.2,
    shear_range=0.2,
    horizontal_flip=True,
    validation_split=0.2   # 🔥 split here
)

Train_ds=train_gen.flow_from_directory(
    '/kaggle/input/datasets/yusufmurtaza01/pediatric-chest-xray-pneumonia-balanced-dataset',
    target_size=(224,224),
    batch_size=32,
    class_mode='binary',
    subset='training',
    seed=123
)



test_gen = ImageDataGenerator(
    rescale=1./255,
    validation_split=0.2

)

test_ds=test_gen.flow_from_directory(
    '/kaggle/input/datasets/yusufmurtaza01/pediatric-chest-xray-pneumonia-balanced-dataset',
    target_size=(224,224),
    batch_size=32,
    class_mode='binary',
    subset='validation',
    seed=123
)


import tensorflow
from tensorflow import keras
from keras.layers import Flatten,Dense,Dropout 
from keras.models import Sequential
from keras.applications.vgg16 import VGG16



Base_model=VGG16(
    weights='imagenet',
    include_top=False,
    input_shape=(224,224,3)
    
)


Base_model.summary()


model=Sequential()
model.add(Base_model)
model.add(Flatten())
model.add(Dense(256,activation='relu'))
model.add(Dense(128,activation='relu'))
model.add(Dense(64,activation='relu'))
model.add(Dense(1,activation='sigmoid'))


model.summary()


Base_model.trainable=False









model.compile(loss='binary_crossentropy',metrics=['accuracy'],optimizer='adam')


from keras.callbacks import EarlyStopping

call=EarlyStopping(
    monitor='val_loss',
    min_delta=0.01,
    patience=5

)


get_ipython().run_line_magic('pinfo2',  'EarlyStopping')


history=model.fit(Train_ds,validation_data=test_ds,epochs=20,callbacks=call)



